# ==========================================
# OKF MD Master - Konfiguration
# ==========================================

# --- LLM Provider (schnell & kostenguenstig) ---
# DeepSeek: https://platform.deepseek.com/api_keys
OKF_MODEL=deepseek-chat
OKF_FALLBACK_MODEL=google/gemma-3-27b-it:free
OKF_MAX_TOKENS=4096
DEEPSEEK_API_KEY=DEIN_DEEPSEEK_KEY
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=DEIN_OPENROUTER_KEY

# --- Scope-Kontrolle ---
# Komma-getrennte Ordner (relativ oder absolut)
WATCH_DIRS=mock_documents
# Maximale Dateigroesse in KB (alles darueber wird ignoriert)
MAX_FILE_SIZE_KB=50

# --- Idle-Detection ---
IDLE_THRESHOLD_SEC=120
CPU_THRESHOLD_PCT=30

# --- Telegram Bot (optional) ---
# Bot ueber @BotFather erstellen
TELEGRAM_BOT_TOKEN=DEIN_BOT_TOKEN
# Deine Chat-ID (ueber @userinfobot herausfinden)
ALLOWED_CHAT_ID=DEINE_CHAT_ID

# --- Server ---
PORT=5000
ADMIN_PIN=180473
