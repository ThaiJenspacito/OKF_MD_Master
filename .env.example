# ==========================================
# OKF MD Master - Configuration
# ==========================================

# --- LLM Provider (fast & cost-effective) ---
# DeepSeek: https://platform.deepseek.com/api_keys
OKF_MODEL=cohere/north-mini-code:free
OKF_FALLBACK_MODEL=deepseek-chat
OKF_MAX_TOKENS=4096
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY

# --- Scope Control ---
# Comma-separated directories (relative or absolute)
WATCH_DIRS=mock_documents
# Max file size in KB (everything above is ignored)
MAX_FILE_SIZE_KB=50

# --- Idle Detection ---
IDLE_THRESHOLD_SEC=120
CPU_THRESHOLD_PCT=30

# --- Server ---
PORT=5000
ADMIN_PIN=180473

# --- Google OAuth (optional) ---
# https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# --- GitHub OAuth (optional) ---
# https://github.com/settings/developers -> New OAuth App
# Callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# --- GitHub Token (for P2P Sync) ---
# https://github.com/settings/tokens
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
